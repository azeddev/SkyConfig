<Window x:Class="SkyConfig.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SkyConfig" Height="780" Width="960" MinHeight="620" MinWidth="820"
        WindowStartupLocation="CenterScreen" AllowDrop="True"
        Drop="Window_Drop" DragOver="Window_DragOver">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New..." InputGestureText="Ctrl+N" Click="New_Click" />
                <MenuItem Header="_Open..." InputGestureText="Ctrl+O" Click="Open_Click" />
                <MenuItem x:Name="CloseMenuItem" Header="_Close" InputGestureText="Ctrl+W" Click="CloseFile_Click" IsEnabled="False" />
                <Separator />
                <MenuItem x:Name="SaveMenuItem" Header="_Save" InputGestureText="Ctrl+S" Click="Save_Click" IsEnabled="False" />
                <MenuItem x:Name="SaveAsMenuItem" Header="Save _As..." InputGestureText="Ctrl+Shift+S" Click="SaveAs_Click" IsEnabled="False" />
                <MenuItem x:Name="RevertMenuItem" Header="_Revert" Click="Revert_Click" IsEnabled="False" />
                <Separator />
                <MenuItem Header="E_xit" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="About_Click" />
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top" BorderBrush="#B8B8B8" BorderThickness="0,0,0,1" Padding="8">
            <StackPanel Orientation="Horizontal">
                <Button Content="New" Click="New_Click" Margin="0,0,6,0" />
                <Button Content="Open" Click="Open_Click" Margin="0,0,6,0" />
                <Button x:Name="CloseButton" Content="Close" Click="CloseFile_Click" IsEnabled="False" Margin="0,0,6,0" />
                <Button x:Name="SaveButton" Content="Save" Click="Save_Click" IsEnabled="False" Margin="0,0,6,0" />
                <Button x:Name="ApplyButton" Content="Apply changes" Click="Apply_Click" IsEnabled="False" />
            </StackPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom" BorderBrush="#B8B8B8" BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Open a .sky file or create a new one." />
            </StatusBarItem>
        </StatusBar>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="2*" MinWidth="270" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <GroupBox Header="File">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Name" Margin="0,4" />
                            <TextBlock x:Name="FileNameText" Grid.Column="1" Margin="0,4" Text="None" />
                            <TextBlock Grid.Row="1" Text="Path" Margin="0,4" />
                            <TextBlock x:Name="FilePathText" Grid.Row="1" Grid.Column="1" Margin="0,4" Text="-" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                            <TextBlock Grid.Row="2" Text="Serial" Margin="0,4" />
                            <TextBlock x:Name="SerialText" Grid.Row="2" Grid.Column="1" Margin="0,4" Text="-" FontFamily="Consolas" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Identity" x:Name="IdentityGroup" IsEnabled="False">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Figure" Margin="0,5" />
                            <ComboBox x:Name="FigureCombo" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,1,0,6"
                                      IsEditable="True" IsTextSearchEnabled="True" TextSearch.TextPath="Name"
                                      DisplayMemberPath="DisplayName" SelectionChanged="FigureCombo_SelectionChanged" />
                            <TextBlock Grid.Row="1" Text="ID (decimal)" Margin="0,5" />
                            <TextBox x:Name="IdBox" Grid.Row="1" Grid.Column="1" Margin="0,1,0,6" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Variant (hex)" Margin="14,5,0,5" />
                            <TextBox x:Name="VariantBox" Grid.Row="1" Grid.Column="3" Margin="0,1,0,6" ToolTip="Hexadecimal" />
                            <TextBlock Grid.Row="2" Text="Classification" Margin="0,5" />
                            <TextBlock x:Name="ClassificationText" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,5" Text="-" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Character data" x:Name="CharacterGroup" IsEnabled="False">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Nickname" Margin="0,5" />
                            <TextBox x:Name="NicknameBox" Grid.Column="1" Grid.ColumnSpan="4" Margin="0,1,0,6"
                                     MaxLength="15" TextChanged="ControlChanged" />

                            <TextBlock Grid.Row="1" Text="Level" Margin="0,5" />
                            <ComboBox x:Name="LevelCombo" Grid.Row="1" Grid.Column="1" Margin="0,1,0,6" SelectionChanged="LevelCombo_SelectionChanged" />
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="Total XP" Margin="0,5" />
                            <TextBox x:Name="ExperienceBox" Grid.Row="1" Grid.Column="4" Margin="0,1,0,6" TextChanged="ExperienceBox_TextChanged" />

                            <TextBlock Grid.Row="2" Text="Gold" Margin="0,5" />
                            <TextBox x:Name="GoldBox" Grid.Row="2" Grid.Column="1" Margin="0,1,0,6" />
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="Play time (sec.)" Margin="0,5" />
                            <TextBox x:Name="PlayTimeBox" Grid.Row="2" Grid.Column="4" Margin="0,1,0,6" />

                            <TextBlock Grid.Row="3" Text="Hero rank" Margin="0,5" />
                            <TextBox x:Name="HeroRankBox" Grid.Row="3" Grid.Column="1" Margin="0,1,0,6" />
                            <TextBlock Grid.Row="3" Grid.Column="3" Text="Upgrade path" Margin="0,5" />
                            <Grid Grid.Row="3" Grid.Column="4" Margin="0,1,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="UpgradePathCombo" SelectionChanged="UpgradePathCombo_SelectionChanged" />
                                <Button Grid.Column="1" Content="Manage..." Click="ManageUpgrades_Click" Margin="6,0,0,0" />
                            </Grid>

                            <TextBlock Grid.Row="4" Text="Heroic flags" Margin="0,5" ToolTip="32-bit hexadecimal completion bitmask" />
                            <TextBox x:Name="HeroicFlagsBox" Grid.Row="4" Grid.Column="1" Margin="0,1,0,6" TextChanged="HeroicFlagsBox_TextChanged" />
                            <TextBlock Grid.Row="4" Grid.Column="3" Text="Completed" Margin="0,5" />
                            <TextBlock x:Name="HeroicCountText" Grid.Row="4" Grid.Column="4" Margin="0,5" Text="0 of 32" />

                            <Expander Grid.Row="5" Grid.ColumnSpan="5" Header="Hat IDs" Margin="0,3,0,6">
                                <Grid Margin="0,7,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Spyro's Adventure" Margin="0,5" />
                                    <TextBox x:Name="SsaHatBox" Grid.Column="1" Margin="0,1,0,6" />
                                    <TextBlock Grid.Column="3" Text="Giants" Margin="0,5" />
                                    <TextBox x:Name="GiantsHatBox" Grid.Column="4" Margin="0,1,0,6" />
                                    <TextBlock Grid.Row="1" Text="Swap / Trap Team" Margin="0,5" />
                                    <TextBox x:Name="SwapHatBox" Grid.Row="1" Grid.Column="1" Margin="0,1,0,0" />
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="SuperChargers" Margin="0,5" />
                                    <TextBox x:Name="SuperHatBox" Grid.Row="1" Grid.Column="4" Margin="0,1,0,0" />
                                </Grid>
                            </Expander>

                            <StackPanel Grid.Row="6" Grid.ColumnSpan="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                <Button Content="Reset progress" Click="ResetProgress_Click" Margin="0,0,6,0" />
                                <Button Content="Max progress" Click="MaxProgress_Click" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <GroupBox Header="Validation">
                        <StackPanel>
                            <TextBlock x:Name="HeaderStatusText" Text="Header: -" Margin="0,2" />
                            <TextBlock x:Name="AreaAStatusText" Text="Area A: -" Margin="0,2" TextWrapping="Wrap" />
                            <TextBlock x:Name="AreaBStatusText" Text="Area B: -" Margin="0,2" TextWrapping="Wrap" />
                            <TextBlock x:Name="ActiveAreaText" Text="Active area: -" Margin="0,7,0,2" FontWeight="SemiBold" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Hex data">
                        <StackPanel>
                            <CheckBox x:Name="DecryptedHexCheckBox" Content="Show decrypted data" IsChecked="True" Checked="HexMode_Changed" Unchecked="HexMode_Changed" Margin="0,0,0,7" />
                            <TextBox x:Name="HexText" Height="410" IsReadOnly="True" AcceptsReturn="True" AcceptsTab="True"
                                     FontFamily="Consolas" FontSize="11" HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap" />
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
