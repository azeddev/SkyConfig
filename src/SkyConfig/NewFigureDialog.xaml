<Window x:Class="SkyConfig.App.NewFigureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Skylander dump" SizeToContent="WidthAndHeight" MinWidth="560"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="150" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Figure" Margin="0,5" />
        <ComboBox x:Name="FigureCombo" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,0,0,10"
                  IsEditable="True" IsTextSearchEnabled="True" TextSearch.TextPath="Name"
                  DisplayMemberPath="DisplayName" SelectionChanged="FigureCombo_SelectionChanged" />
        <TextBlock Grid.Row="1" Text="ID (decimal)" Margin="0,5" />
        <TextBox x:Name="IdBox" Grid.Row="1" Grid.Column="1" Margin="0,0,10,10" />
        <TextBlock Grid.Row="1" Grid.Column="2" Text="Variant (hex)" Margin="0,5" />
        <TextBox x:Name="VariantBox" Grid.Row="1" Grid.Column="3" Margin="0,0,0,10" />

        <StackPanel Grid.Row="2" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Create" IsDefault="True" Click="Create_Click" Margin="0,0,7,0" />
            <Button Content="Cancel" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>

