<Window x:Class="SkyConfig.App.UpgradeManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upgrade manager" Height="700" Width="620" MinHeight="560" MinWidth="520"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="CanResizeWithGrip">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock x:Name="FigureNameText" FontSize="16" FontWeight="SemiBold" />
            <TextBlock x:Name="CatalogStatusText" Margin="0,4,0,0" Foreground="#555555" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Separator Margin="0,0,0,10" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Clear all" Click="ClearAll_Click" Margin="0,0,6,0" />
                    <Button Content="Unlock selected path" Click="UnlockSelected_Click" Margin="0,0,6,0" />
                    <Button Content="Unlock all" Click="UnlockAll_Click" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="OK" Width="76" IsDefault="True" Click="Ok_Click" Margin="0,0,6,0" />
                    <Button Content="Cancel" Width="76" IsCancel="True" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Path selection">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Active path" Margin="0,5" />
                        <ComboBox x:Name="PathCombo" Grid.Column="1" DisplayMemberPath="Label"
                                  SelectionChanged="UpgradeControl_Changed" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Base upgrades">
                    <StackPanel>
                        <CheckBox x:Name="Base1Check" Checked="UpgradeControl_Changed" Unchecked="UpgradeControl_Changed" />
                        <CheckBox x:Name="Base2Check" Checked="UpgradeControl_Changed" Unchecked="UpgradeControl_Changed" />
                        <CheckBox x:Name="Base3Check" Checked="UpgradeControl_Changed" Unchecked="UpgradeControl_Changed" />
                        <CheckBox x:Name="Base4Check" Checked="UpgradeControl_Changed" Unchecked="UpgradeControl_Changed" />
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="PrimaryGroup">
                    <StackPanel>
                        <CheckBox x:Name="Primary1Check" Checked="UpgradeControl_Changed" Unchecked="UpgradeControl_Changed" />
                        <CheckBox x:Name="Primary2Check" Checked="UpgradeControl_Changed" Unchecked="UpgradeControl_Changed" />
                        <CheckBox x:Name="Primary3Check" Checked="UpgradeControl_Changed" Unchecked="UpgradeControl_Changed" />
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="SecondaryGroup">
                    <StackPanel>
                        <CheckBox x:Name="Secondary1Check" Checked="UpgradeControl_Changed" Unchecked="UpgradeControl_Changed" />
                        <CheckBox x:Name="Secondary2Check" Checked="UpgradeControl_Changed" Unchecked="UpgradeControl_Changed" />
                        <CheckBox x:Name="Secondary3Check" Checked="UpgradeControl_Changed" Unchecked="UpgradeControl_Changed" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Special upgrades">
                    <StackPanel>
                        <CheckBox x:Name="SoulGemCheck" Checked="UpgradeControl_Changed" Unchecked="UpgradeControl_Changed" />
                        <CheckBox x:Name="WowPowCheck" Checked="UpgradeControl_Changed" Unchecked="UpgradeControl_Changed" />
                    </StackPanel>
                </GroupBox>

                <Border BorderBrush="#B8B8B8" BorderThickness="1" Padding="8" Margin="0,6,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Encoded upgrade flags" />
                        <TextBlock x:Name="RawBitsText" Margin="12,0,0,0" FontFamily="Consolas" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
